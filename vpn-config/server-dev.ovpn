#Protocol settings
tls-server
tls-version-min 1.2
tls-cipher TLS-ECDHE-RSA-WITH-AES-256-GCM-SHA384
proto tcp-server

#Device type
dev tun

#Logging
log-append "./log/openvpn.log"
verb 3

#Keys
ca "./keys/root.crt"
key "./keys/server.key"
cert "./keys/server.crt"
dh "./keys/dh.pem"

#Authentication
auth SHA256

#Misc
management localhost 7505
keepalive 10 60
topology subnet
user nobody
group nogroup
persist-key
persist-tun
